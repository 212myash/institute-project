# Database Configuration (example only)
# Keep MONGO_URI private. Do not share in chats, screenshots, or public repositories.
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/institute-db?retryWrites=true&w=majority

# JWT Secret Key (example only)
# Keep JWT_SECRET private. Use a long random value in production.
JWT_SECRET=replace_with_a_long_random_secret

# Server Configuration
PORT=5000
NODE_ENV=development
